<view class="page">
  <view class="hero">
    <view class="hero-title">🛰️ 专题情报</view>
    <view class="hero-sub">围绕指定专题的深度情报合集，非定期更新；每次发起聚合近 3 年、约 18 篇国内外内容。</view>
  </view>

  <view class="searchbar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索专题标题/简介"
        value="{{searchText}}"
        confirm-type="search"
        bindinput="onSearchInput"
      />
      <text wx:if="{{searchText}}" class="search-clear" bindtap="clearSearch">×</text>
    </view>
  </view>

  <view wx:if="{{searchText}}" class="sortbar">
    <view class="chip small {{searchScope === 'all' ? 'on' : ''}}" data-scope="all" bindtap="switchSearchScope">标题+简介</view>
    <view class="chip small {{searchScope === 'title' ? 'on' : ''}}" data-scope="title" bindtap="switchSearchScope">仅标题</view>
    <text class="search-total">共 {{shown.length}} 条</text>
  </view>

  <view class="list">
    <view
      wx:for="{{shown}}"
      wx:key="id"
      class="topic-card"
      data-id="{{item.id}}"
      bindtap="openTopic"
    >
      <view class="tc-top">
        <text class="tc-title">{{item.title}}</text>
        <text class="tc-arrow">›</text>
      </view>
      <view class="tc-intro">{{item.intro}}</view>
      <view class="tc-foot">
        <text class="tc-badge">{{item.count}} 篇</text>
        <text class="tc-badge ghost">近 {{item.years}} 年</text>
        <text wx:if="{{item.updated_at}}" class="tc-time">更新 {{item.updated_at}}</text>
        <text wx:else class="tc-time">待生成</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="hint">正在加载专题…</view>
    <view wx:if="{{!loading && error}}" class="hint">{{error}}</view>
    <view wx:if="{{!loading && !error && !topics.length}}" class="hint">暂无专题</view>
    <view wx:if="{{!loading && !error && topics.length && !shown.length}}" class="hint">没有找到匹配的专题</view>
  </view>
</view>
