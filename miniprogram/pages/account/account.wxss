.auth-head { text-align: center; padding: 40rpx 0 30rpx; }
.auth-logo { font-size: 90rpx; }
.auth-title { font-size: 40rpx; font-weight: 700; margin-top: 10rpx; }
.auth-sub { color: var(--sub); font-size: 26rpx; margin-top: 8rpx; }

.seg {
  display: flex;
  background: #f1f4fa;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  color: var(--sub);
  font-size: 28rpx;
}
.seg-item.on { background: #fff; color: var(--brand); font-weight: 600; box-shadow: 0 4rpx 12rpx rgba(20,40,90,0.06); }

.profile { display: flex; align-items: center; }
.avatar {
  width: 110rpx; height: 110rpx; border-radius: 50%;
  background: linear-gradient(135deg, #2f6bff, #5aa0ff);
  color: #fff; font-size: 48rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-right: 26rpx;
}
.p-name { font-size: 36rpx; font-weight: 700; }
.p-acc { color: var(--muted); font-size: 26rpx; margin-top: 8rpx; }
.badge {
  font-size: 22rpx; color: #fff; background: var(--brand);
  border-radius: 8rpx; padding: 4rpx 14rpx; margin-left: 14rpx; font-weight: 500;
}
.badge.sm { font-size: 20rpx; padding: 2rpx 10rpx; }

.cell {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 4rpx; border-bottom: 2rpx solid var(--line);
  font-size: 30rpx;
}
.cell:last-child { border-bottom: none; }
.arrow { color: var(--muted); }
.danger-text { color: #ff5b5b; }

.sec-title { color: var(--sub); font-size: 26rpx; margin: 30rpx 6rpx 16rpx; }

.dy-status { display: flex; align-items: center; font-size: 27rpx; }
.dy-status .dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-right: 14rpx; }
.dy-status.ok { color: #1a9e57; }
.dy-status.ok .dot { background: #1a9e57; }
.dy-status.bad { color: #d6326b; }
.dy-status.bad .dot { background: #d6326b; }
.dy-recent { margin-top: 14rpx; }
.dy-item { color: var(--sub); font-size: 24rpx; line-height: 1.7; }
.ta {
  width: 100%; box-sizing: border-box;
  background: #f5f7fb; border: 2rpx solid #eef1f6; border-radius: 16rpx;
  padding: 20rpx; font-size: 24rpx; min-height: 140rpx; margin-top: 10rpx;
}

.u-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 4rpx; border-bottom: 2rpx solid var(--line);
}
.u-row:last-child { border-bottom: none; }
.u-name { font-size: 30rpx; font-weight: 600; }
.u-acc { color: var(--muted); font-size: 24rpx; margin-top: 6rpx; }
