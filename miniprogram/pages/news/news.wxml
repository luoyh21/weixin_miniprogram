<view class="page">
  <view class="filterbar">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="chip {{active === item.key ? 'on' : ''}}"
      data-key="{{item.key}}"
      bindtap="switchFilter"
    >{{item.label}}</view>
  </view>

  <view class="list">
    <block wx:if="{{!loading && groups.length}}">
      <view wx:for="{{groups}}" wx:key="date" class="day-group">
        <view class="day-head">
          <text class="day-label">{{item.label}}</text>
          <text class="day-count">{{item.items.length}} 条</text>
        </view>

        <view
          wx:for="{{item.items}}"
          wx:for-item="news"
          wx:key="id"
          class="news-card"
          data-id="{{news.id}}"
          bindtap="openDetail"
        >
          <view class="nc-body">
            <view class="nc-tagline">
              <text class="tag {{news.kind}}">#{{news.main_tag}}</text>
              <text class="nc-source">{{news.source}}</text>
            </view>
            <view class="nc-title">{{news.title}}</view>
            <view class="nc-summary">{{news.summary}}</view>
            <view class="nc-meta">{{news.published}}</view>
          </view>
          <image wx:if="{{news.image && !imgErr[news.id]}}" class="nc-thumb" src="{{news.image}}" mode="aspectFill" lazy-load="true" binderror="onImgError" data-id="{{news.id}}" />
        </view>
      </view>
    </block>

    <view wx:if="{{loading}}" class="hint">正在加载近两周速递…</view>
    <view wx:if="{{!loading && error}}" class="hint">{{error}}</view>
    <view wx:if="{{!loading && !error && !groups.length}}" class="hint">近两周暂无该类内容</view>
    <view wx:if="{{!loading && !error && groups.length && loadingMore}}" class="hint">加载中…</view>
    <view wx:if="{{!loading && !error && groups.length && hasMore && !loadingMore}}" class="hint">上拉加载更多…</view>
    <view wx:if="{{!loading && !error && groups.length && !hasMore}}" class="hint">已经到底啦 · 近两周速递</view>
  </view>
</view>
