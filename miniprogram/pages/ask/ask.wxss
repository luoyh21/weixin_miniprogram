.ask-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}
.msgs {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.welcome { padding: 40rpx 20rpx; }
.w-title { font-size: 40rpx; font-weight: 700; }
.w-sub { color: var(--sub); font-size: 26rpx; margin-top: 14rpx; line-height: 1.6; }
.sugs { margin-top: 30rpx; }
.sug {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  color: var(--ink);
  box-shadow: 0 4rpx 16rpx rgba(20, 40, 90, 0.05);
}

.msg { display: flex; margin-bottom: 24rpx; }
.msg.user { justify-content: flex-end; }
.msg.ai { justify-content: flex-start; }
.bubble {
  max-width: 78%;
  padding: 22rpx 26rpx;
  border-radius: 22rpx;
  font-size: 29rpx;
  line-height: 1.65;
  word-break: break-word;
}
.bubble.user { background: var(--brand); color: #fff; border-bottom-right-radius: 6rpx; }
.bubble.ai { background: #fff; color: var(--ink); border-bottom-left-radius: 6rpx; box-shadow: 0 4rpx 16rpx rgba(20,40,90,0.06); }
.bubble.pending { color: var(--muted); }

.links { margin-top: 18rpx; }
.link-chip {
  display: inline-block;
  background: rgba(47,107,255,0.08);
  color: var(--brand);
  font-size: 24rpx;
  border-radius: 10rpx;
  padding: 10rpx 18rpx;
  margin: 0 12rpx 12rpx 0;
}

.login-tip {
  text-align: center;
  color: var(--brand);
  font-size: 26rpx;
  padding: 16rpx;
  background: rgba(47,107,255,0.06);
}

.inputbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid var(--line);
}
.ti {
  flex: 1;
  background: #f3f5fa;
  border-radius: 999rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
}
.send-btn {
  flex: none;
  background: var(--brand);
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 36rpx;
  line-height: 72rpx;
  height: 72rpx;
}
.send-btn[disabled] { background: #b9ccff; color:#fff; }
