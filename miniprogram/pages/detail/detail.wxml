<view class="container" wx:if="{{item}}">
  <view class="d-tags">
    <text wx:for="{{item.tags}}" wx:for-item="tg" wx:key="*this"
      class="tag {{item.kind}}">#{{tg}}</text>
  </view>
  <view class="d-title">{{item.title}}</view>
  <view class="d-meta">{{item.source}} · {{item.published}}</view>

  <image wx:if="{{item.image}}" class="d-hero" src="{{item.image}}" mode="widthFix" />

  <!-- 政要社媒：结构化展示 渠道 / 原文 / 译文 / 解读 -->
  <block wx:if="{{item.kind === 'social'}}">
    <view class="s-block">
      <view class="s-label">发布渠道</view>
      <view class="s-val">{{item.channel}}</view>
    </view>
    <view class="s-block" wx:if="{{item.original}}">
      <view class="s-label">原文</view>
      <view class="s-orig">{{item.original}}</view>
    </view>
    <view class="s-block" wx:if="{{item.translation}}">
      <view class="s-label">中文翻译</view>
      <view class="s-val">{{item.translation}}</view>
    </view>
    <view class="s-block s-analysis" wx:if="{{item.analysis}}">
      <view class="s-label">🛰 航天视角解读</view>
      <view class="s-val">{{item.analysis}}</view>
    </view>
  </block>
  <!-- 技术港：项目结构化信息（尽量展示全部入库字段） -->
  <block wx:elif="{{item.kind === 'techport'}}">
    <view class="meta-card">
      <view class="meta-row" wx:if="{{item.project_id}}"><text class="meta-k">项目 ID</text><text class="meta-v">{{item.project_id}}</text></view>
      <view class="meta-row" wx:if="{{item.title_en}}"><text class="meta-k">英文标题</text><text class="meta-v">{{item.title_en}}</text></view>
      <view class="meta-row" wx:if="{{item.acronym}}"><text class="meta-k">缩写</text><text class="meta-v">{{item.acronym}}</text></view>
      <view class="meta-row" wx:if="{{item.status_zh}}"><text class="meta-k">项目状态</text><text class="meta-v">{{item.status_zh}}<text wx:if="{{item.status && item.status !== item.status_zh}}">（{{item.status}}）</text></text></view>
      <view class="meta-row" wx:if="{{item.period}}"><text class="meta-k">项目周期</text><text class="meta-v">{{item.period}}</text></view>
      <view class="meta-row" wx:if="{{item.start_date}}"><text class="meta-k">开始时间</text><text class="meta-v">{{item.start_date}}</text></view>
      <view class="meta-row" wx:if="{{item.end_date}}"><text class="meta-k">结束时间</text><text class="meta-v">{{item.end_date}}</text></view>
      <view class="meta-row" wx:if="{{item.trl}}"><text class="meta-k">技术成熟度</text><text class="meta-v">{{item.trl}}</text></view>
      <view class="meta-row" wx:if="{{item.category_disp || item.category}}"><text class="meta-k">技术类别</text><text class="meta-v">{{item.category_disp || item.category}}</text></view>
      <view class="meta-row" wx:if="{{item.program_disp || item.program}}"><text class="meta-k">所属计划</text><text class="meta-v">{{item.program_disp || item.program}}</text></view>
      <view class="meta-row" wx:if="{{item.directorate}}"><text class="meta-k">主管司局</text><text class="meta-v">{{item.directorate}}</text></view>
      <view class="meta-row" wx:if="{{item.lead_org}}"><text class="meta-k">牵头机构</text><text class="meta-v">{{item.lead_org}}</text></view>
      <view class="meta-row" wx:if="{{item.destinations}}"><text class="meta-k">任务目的地</text><text class="meta-v">{{item.destinations}}</text></view>
      <view class="meta-row" wx:if="{{item.updated_raw}}"><text class="meta-k">源站更新</text><text class="meta-v">{{item.updated_raw}}</text></view>
      <view class="meta-row" wx:if="{{item.website}}"><text class="meta-k">项目网站</text><text class="meta-v">{{item.website}}</text></view>
    </view>
    <view class="d-body">
      <view wx:for="{{paragraphs}}" wx:key="index" class="d-p">{{item}}</view>
    </view>
    <view class="s-block" wx:if="{{item.benefits || item.benefits_en}}">
      <view class="s-label">项目收益</view>
      <view class="s-val" wx:if="{{item.benefits}}">{{item.benefits}}</view>
      <view class="s-orig" wx:if="{{item.benefits_en}}">{{item.benefits_en}}</view>
    </view>
    <view class="s-block" wx:if="{{item.summary_en}}">
      <view class="s-label">英文原文</view>
      <view class="s-orig">{{item.summary_en}}</view>
    </view>
  </block>

  <!-- 每日发射：结构化信息 -->
  <block wx:elif="{{item.kind === 'launch'}}">
    <view class="meta-card">
      <view class="meta-row" wx:if="{{item.provider_zh}}"><text class="meta-k">发射提供方</text><text class="meta-v">{{item.provider_zh}}</text></view>
      <view class="meta-row" wx:if="{{item.location_zh}}"><text class="meta-k">发射场</text><text class="meta-v">{{item.location_zh}}</text></view>
      <view class="meta-row" wx:if="{{item.net_bj}}"><text class="meta-k">计划时间</text><text class="meta-v">{{item.net_bj}} 北京</text></view>
      <view class="meta-row" wx:if="{{item.status}}"><text class="meta-k">状态</text><text class="meta-v">{{item.status}}</text></view>
    </view>
    <view class="d-body" wx:if="{{paragraphs.length}}">
      <view wx:for="{{paragraphs}}" wx:key="index" class="d-p">{{item}}</view>
    </view>
  </block>

  <!-- 未来发射看板：未来 30 天发射逐条 -->
  <block wx:elif="{{item.kind === 'future'}}">
    <view class="fut-head">近{{item.future_days}}天共 {{item.future_count}} 次发射<text wx:if="{{item.future_updated}}" class="fut-upd"> · 更新于 {{item.future_updated}}</text></view>
    <view class="fut-list">
      <view wx:for="{{item.launches}}" wx:for-item="lc" wx:key="net" class="fut-item">
        <view class="fut-time">{{lc.net_bj}}<text class="fut-badge">北京</text></view>
        <view class="fut-name">{{lc.name_en}}</view>
        <view class="fut-sub">{{lc.provider_zh}}<text wx:if="{{lc.location_zh}}"> · {{lc.location_zh}}</text></view>
        <view class="fut-status" wx:if="{{lc.status}}">{{lc.status}}</view>
      </view>
    </view>
    <view wx:if="{{!item.launches.length}}" class="muted center">未来暂无已排期发射</view>
  </block>

  <!-- 国际要闻：正文前展示内容概要；文末附英文原文（若有） -->
  <block wx:elif="{{item.kind === 'intl'}}">
    <view class="blurb" wx:if="{{item.summary_zh}}">
      <view class="blurb-label">内容概要</view>
      <view class="blurb-txt">{{item.summary_zh}}</view>
    </view>
    <view class="d-body">
      <view wx:for="{{paragraphs}}" wx:key="index" class="d-p">{{item}}</view>
    </view>
    <view wx:if="{{item.images.length}}" class="d-gallery">
      <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
        class="d-gimg" src="{{img}}" mode="widthFix" lazy-load="true" />
    </view>
    <view class="s-block" wx:if="{{item.body_en || item.summary_en}}">
      <view class="s-label">英文原文</view>
      <view class="s-orig">{{item.body_en || item.summary_en}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="d-body">
      <view wx:for="{{paragraphs}}" wx:key="index" class="d-p">{{item}}</view>
    </view>
    <view wx:if="{{item.images.length}}" class="d-gallery">
      <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
        class="d-gimg" src="{{img}}" mode="widthFix" lazy-load="true" />
    </view>
  </block>

  <!-- 小程序无法直接跳转外部 App/公众号，提供「复制 + 步骤」引导 -->
  <block wx:if="{{item.kind === 'douyin'}}">
    <view class="d-guide">
      <view class="d-guide-t">▶️ 如何观看完整视频</view>
      <view class="d-guide-s">1. 点击下方「复制抖音口令」</view>
      <view class="d-guide-s">2. 打开抖音 App</view>
      <view class="d-guide-s">3. 点击顶部搜索框，粘贴口令后搜索，即可观看该视频</view>
    </view>
    <view wx:if="{{item.link}}" class="d-url"><text class="d-url-k">网址</text><text class="d-url-v" selectable="true" user-select="true" space="nbsp">{{item.link}}</text></view>
    <view class="d-actions">
      <button wx:if="{{item.share_text}}" class="btn" bindtap="copyShare">复制抖音口令</button>
      <button class="btn ghost" bindtap="copyLink" style="margin-top:18rpx;">复制视频链接</button>
    </view>
  </block>
  <block wx:elif="{{item.kind === 'gzh'}}">
    <view class="d-guide">
      <view class="d-guide-t">📰 如何阅读公众号原文</view>
      <view class="d-guide-s">1. 点击下方「复制标题」</view>
      <view class="d-guide-s">2. 点击微信右上角的搜索框</view>
      <view class="d-guide-s">3. 粘贴标题后搜索，即可打开该公众号文章</view>
    </view>
    <view wx:if="{{item.link}}" class="d-url"><text class="d-url-k">网址</text><text class="d-url-v" selectable="true" user-select="true" space="nbsp">{{item.link}}</text></view>
    <view class="d-actions">
      <button class="btn" bindtap="copyTitle">复制标题</button>
      <button class="btn ghost" bindtap="copyLink" style="margin-top:18rpx;">复制原文链接</button>
    </view>
  </block>
  <block wx:elif="{{item.kind === 'social'}}">
    <view class="d-guide">
      <view class="d-guide-t">🔗 查看原帖</view>
      <view class="d-guide-s">点击下方「复制原帖链接」，在浏览器打开即可查看 {{item.author_name}} 的原始帖子</view>
    </view>
    <view wx:if="{{item.link}}" class="d-url"><text class="d-url-k">网址</text><text class="d-url-v" selectable="true" user-select="true" space="nbsp">{{item.link}}</text></view>
    <view class="d-actions">
      <button class="btn ghost" bindtap="copyLink">复制原帖链接</button>
    </view>
  </block>
  <block wx:else>
    <view wx:if="{{item.link}}" class="d-url"><text class="d-url-k">网址</text><text class="d-url-v" selectable="true" user-select="true" space="nbsp">{{item.link}}</text></view>
    <view class="d-actions">
      <button class="btn ghost" bindtap="copyLink">复制原文链接</button>
    </view>
  </block>
  <view class="muted center" style="margin-top:24rpx;">译文与解读由 AI 生成，仅供参考，以原文为准</view>
</view>

<view wx:if="{{loading}}" class="hint">加载中…</view>
<view wx:if="{{!loading && error}}" class="hint">{{error}}</view>
