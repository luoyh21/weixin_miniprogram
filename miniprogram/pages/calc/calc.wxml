<view class="page">
  <view class="filterbar">
    <view class="chip on">全部</view>
  </view>

  <view class="list">
    <view class="day-group">
      <view class="day-head">
        <text class="day-label">计算演示</text>
        <text class="day-count">{{items.length}} 条</text>
      </view>

      <view wx:for="{{items}}" wx:key="id" class="news-card">
        <view class="nc-body">
          <view class="nc-tagline">
            <text class="tag">#计算</text>
            <text class="nc-source">计算演示</text>
          </view>
          <view class="nc-title">{{item.title}}</view>
          <view class="nc-summary">{{item.summary}}</view>
          <view class="nc-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
