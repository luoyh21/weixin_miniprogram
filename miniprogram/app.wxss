page {
  --bg: #eef2f7;
  --card: #ffffff;
  --ink: #1b2330;
  --sub: #6b7585;
  --muted: #9aa3b2;
  --brand: #2f6bff;
  --brand-deep: #0b1f3a;
  --line: #eceff4;
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(20, 40, 90, 0.06);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
}

.btn {
  display: block;
  width: 100%;
  background: var(--brand);
  color: #fff;
  border-radius: 999rpx;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 1.2;
}
.btn[disabled] { background: #b9ccff; color: #fff; }
.btn.ghost {
  background: #f1f4fa;
  color: var(--ink);
}
.btn.danger { background: #ff5b5b; }
.btn.small { width: auto; display: inline-block; padding: 12rpx 26rpx; font-size: 24rpx; }

.input {
  background: #f5f7fb;
  border: 2rpx solid #eef1f6;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.label { color: var(--sub); font-size: 26rpx; margin-bottom: 10rpx; }

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: var(--brand);
  background: rgba(47, 107, 255, 0.1);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  margin: 0 12rpx 12rpx 0;
}
.tag.gzh { color: #e07b00; background: rgba(224, 123, 0, 0.1); }
.tag.douyin { color: #d6326b; background: rgba(214, 50, 107, 0.1); }

.muted { color: var(--muted); font-size: 24rpx; }
.center { text-align: center; }
.hint { color: var(--muted); font-size: 24rpx; text-align: center; padding: 40rpx 0; }
