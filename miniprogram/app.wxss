page {
  --bg: #eef2f7;
  --card: #ffffff;
  --ink: #1b2330;
  --sub: #6b7585;
  --muted: #9aa3b2;
  --brand: #2f6bff;
  --brand-deep: #0b1f3a;
  --line: #eceff4;
  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(20, 40, 90, 0.06);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.row {
  display: flex;
  align-items: center;
}

.btn {
  display: block;
  width: 100%;
  background: var(--brand);
  color: #fff;
  border-radius: 999rpx;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  line-height: 1.2;
}
.btn[disabled] { background: #b9ccff; color: #fff; }
.btn.ghost {
  background: #f1f4fa;
  color: var(--ink);
}
.btn.danger { background: #ff5b5b; }
.btn.small { width: auto; display: inline-block; padding: 12rpx 26rpx; font-size: 24rpx; }

.input {
  background: #f5f7fb;
  border: 2rpx solid #eef1f6;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.label { color: var(--sub); font-size: 26rpx; margin-bottom: 10rpx; }

.tag {
  display: inline-block;
  font-size: 22rpx;
  color: var(--brand);
  background: rgba(47, 107, 255, 0.1);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  margin: 0 12rpx 12rpx 0;
}
.tag.gzh { color: #e07b00; background: rgba(224, 123, 0, 0.1); }
.tag.douyin { color: #d6326b; background: rgba(214, 50, 107, 0.1); }
.tag.social { color: #6a3df5; background: rgba(106, 61, 245, 0.1); }
.tag.techport { color: #0e8a6e; background: rgba(14, 138, 110, 0.1); }
.tag.launch { color: #c2410c; background: rgba(194, 65, 12, 0.1); }
.tag.debris { color: #5b6470; background: rgba(91, 100, 112, 0.1); }

.muted { color: var(--muted); font-size: 24rpx; }
.center { text-align: center; }
.hint { color: var(--muted); font-size: 24rpx; text-align: center; padding: 40rpx 0; }

/* ---- 搜索栏（速递/专题列表/专题内部通用）：模糊搜索输入 + 时间/匹配度排序切换 ---- */
.searchbar {
  padding: 16rpx 24rpx 4rpx;
  background: var(--bg);
}
.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 999rpx;
  padding: 14rpx 22rpx;
  box-shadow: 0 4rpx 14rpx rgba(20, 40, 90, 0.05);
}
.search-icon { font-size: 26rpx; margin-right: 10rpx; opacity: 0.6; }
.search-input { flex: 1; font-size: 27rpx; color: var(--ink); }
.search-clear {
  color: var(--muted);
  font-size: 32rpx;
  line-height: 1;
  padding: 0 6rpx 0 14rpx;
}
.sortbar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 24rpx 4rpx;
}
.chip.small { padding: 8rpx 22rpx; font-size: 23rpx; }
.search-total { margin-left: auto; color: var(--muted); font-size: 22rpx; }
